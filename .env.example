APP_NAME="Laravel"
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------------------------------------
# Mail Settings (Local Development - e.g., Mailpit)
# Uncomment these for local development to catch emails in Mailpit or similar
# --------------------------------------------------------------------------
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# MAIL_FROM_ADDRESS="hello@example.com"
# MAIL_FROM_NAME="${APP_NAME}"

# MAIL_NOREPLY_HOST=mailpit
# MAIL_NOREPLY_PORT=1025
# MAIL_NOREPLY_USERNAME=null
# MAIL_NOREPLY_PASSWORD=null
# MAIL_NOREPLY_ENCRYPTION=null
# MAIL_NOREPLY_FROM_ADDRESS="no_reply@example.com"
# MAIL_NOREPLY_FROM_NAME="${APP_NAME}"


# --------------------------------------------------------------------------
# Mail Settings (Production - e.g., ecr-ts.com)
# Uncomment these for production/live environment
# --------------------------------------------------------------------------
# MAIL_MAILER=smtp
# MAIL_HOST=ecr-ts.com
# MAIL_PORT=465
# MAIL_USERNAME=info@ecr-ts.com
# MAIL_PASSWORD=your_info_password # IMPORTANT: Replace with your actual password
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=info@ecr-ts.com
# MAIL_FROM_NAME="${APP_NAME}"

# MAIL_NOREPLY_HOST=ecr-ts.com
# MAIL_NOREPLY_PORT=465
# MAIL_NOREPLY_USERNAME=no_reply@ecr-ts.com
# MAIL_NOREPLY_PASSWORD=your_no_reply_password # IMPORTANT: Replace with your actual password
# MAIL_NOREPLY_ENCRYPTION=ssl
# MAIL_NOREPLY_FROM_ADDRESS=no_reply@ecr-ts.com
# MAIL_NOREPLY_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

CLOUDINARY_URL="cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME"
